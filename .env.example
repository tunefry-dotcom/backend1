ENV=development
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
FRONTEND_URL=http://localhost:5173

# Supabase — from Project Settings → API
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon/publishable key>
SUPABASE_SERVICE_ROLE_KEY=<service-role key>   # never expose to browser

# Only set if your project has NOT migrated to asymmetric JWKS keys (check Project Settings → JWT)
# SUPABASE_JWT_SECRET=<HS256 secret>

# OAuth
GOOGLE_OAUTH_ENABLED=false
OAUTH_CALLBACK_BASE_URL=http://localhost:8000

# Optional second allowed CORS origin (e.g. http://localhost:5173 when FRONTEND_URL is production).
EXTRA_CORS_ORIGIN=

# Dev testing only: enables POST /auth/dev/create-user (pre-confirmed users, no email).
# Keep false in production.
DEV_AUTH_ENABLED=false

# Admin panel — sent as X-Admin-Secret header. Set a strong random value.
ADMIN_SECRET=

# Razorpay — from Dashboard → Settings → API Keys. SECRETS: never commit real values.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# 100 = testing (charges 1/100th of the price, e.g. ₹14.39 for a ₹1439 plan).
# Set to 1 in production to charge the real amount.
PAYMENT_AMOUNT_DIVISOR=100
